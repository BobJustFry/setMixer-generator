# Database
DATABASE_URL=postgresql://setmixer:setmixer@postgres:5432/setmixer?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Auth
SESSION_SECRET=change-me-to-random-64-char-string
ENCRYPTION_KEY=change-me-to-32-byte-hex-key-for-oauth-tokens

# Admin seed (first deploy)
ADMIN_EMAIL=admin@setmixer.ru
ADMIN_PASSWORD=change-me

# Paths
DATA_DIR=/data

# YouTube OAuth (Google Cloud Console)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://setmixer.ru/api/youtube/callback

# AI image generation (Replicate)
REPLICATE_API_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://setmixer.ru
NODE_ENV=production
