# Database (Docker)
DATABASE_URL=postgresql://setmixer:setmixer@postgres:5432/setmixer?schema=public
REDIS_URL=redis://redis:6379
DATA_DIR=/data

# App URL (можно также задать в интерфейсе настроек)
# Локально:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# С доменом и Caddy на :3000 (см. docs/HTTPS_SETUP.md):
# NEXT_PUBLIC_APP_URL=https://ytb.gnh-nur.ru:3000
NODE_ENV=production

# Доступ к панели (обязательно при публичном :3000)
APP_PASSWORD=change-me-to-a-strong-password
# Сессия входа (32+ символов; можно совпадать с ENCRYPTION_KEY)
SESSION_SECRET=

# YouTube, ComfyUI — настраиваются в интерфейсе: Настройки
# Ниже — только fallback для первого запуска (необязательно)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# COMFYUI_URL=http://host.docker.internal:8000
# COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
# ENCRYPTION_KEY=
