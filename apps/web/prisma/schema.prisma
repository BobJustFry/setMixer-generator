generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mix {
  id           String     @id @default(cuid())
  filename     String
  filepath     String     @unique
  title        String?
  durationSec  Float?
  fileSize     BigInt?
  waveformPath String?
  scanStatus   String     @default("pending")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  videoJobs    VideoJob[]
  backgrounds  MixBackground[]
}

model VideoJob {
  id              String          @id @default(cuid())
  mixId           String
  mix             Mix             @relation(fields: [mixId], references: [id], onDelete: Cascade)
  template        String          @default("waveform_dark")
  encodeSettings  Json?
  backgroundId    String?
  background      MixBackground?  @relation(fields: [backgroundId], references: [id], onDelete: SetNull)
  status          String          @default("pending")
  title           String?
  stylePrompt     String?
  errorMessage    String?
  progress        Int             @default(0)
  stage           String?
  stageProgress   Int             @default(0)
  stageDetail     String?
  cancelRequested Boolean         @default(false)
  segments        Segment[]
  generatedVideo  GeneratedVideo?
  youtubeUpload   YouTubeUpload?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([mixId])
}

model MixBackground {
  id           String     @id @default(cuid())
  mixId        String?
  mix          Mix?       @relation(fields: [mixId], references: [id], onDelete: SetNull)
  source       String
  prompt       String?
  negativePrompt String?
  label        String?
  coverText    String?
  referenceImagePath String?
  imagePath    String?
  width        Int        @default(1920)
  height       Int        @default(1080)
  sourceWidth  Int?
  sourceHeight Int?
  fitMode      String     @default("cover")
  seed         Int?
  status       String     @default("ready")
  errorMessage String?
  createdAt    DateTime   @default(now())
  videoJobs    VideoJob[]

  @@index([mixId])
}

model Segment {
  id          String   @id @default(cuid())
  videoJobId  String
  videoJob    VideoJob @relation(fields: [videoJobId], references: [id], onDelete: Cascade)
  index       Int
  startSec    Float
  endSec      Float
  confidence  Float    @default(0)
  label       String?
  thumbPrompt String?
  thumbPath   String?
  source      String   @default("auto")

  @@index([videoJobId])
}

model GeneratedVideo {
  id           String   @id @default(cuid())
  videoJobId   String   @unique
  videoJob     VideoJob @relation(fields: [videoJobId], references: [id], onDelete: Cascade)
  outputPath   String
  durationSec  Float?
  previewPath  String?
  ffmpegLog    String?
  createdAt    DateTime @default(now())
}

model YouTubeUpload {
  id              String    @id @default(cuid())
  videoJobId      String    @unique
  videoJob        VideoJob  @relation(fields: [videoJobId], references: [id], onDelete: Cascade)
  title           String
  description     String
  tags            String[]
  categoryId      String    @default("10")
  privacyStatus   String    @default("private")
  publishAt       DateTime?
  playlistId      String?
  playlistTitle   String?
  uploadStatus    String    @default("draft")
  youtubeVideoId  String?
  errorMessage    String?
  uploadedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model YouTubeCredential {
  id                    String   @id @default("default")
  encryptedRefreshToken String
  channelTitle          String?
  channelId             String?
  updatedAt             DateTime @updatedAt
}

model AppSettings {
  id                  String   @id @default("default")
  encryptionKey       String
  youtubeClientId     String?
  youtubeClientSecret String?
  comfyuiUrl          String?  @default("http://host.docker.internal:8000")
  comfyuiCheckpoint   String?  @default("flux1-dev-fp8.safetensors")
  comfyuiConnected    Boolean  @default(false)
  comfyuiLastError    String?
  appUrl              String   @default("http://localhost:3000")
  updatedAt           DateTime @updatedAt
}

model BackgroundTask {
  id              String   @id @default(cuid())
  type            String
  title           String
  status          String   @default("pending")
  progress        Int      @default(0)
  stage           String?
  stageProgress   Int      @default(0)
  stageDetail     String?
  videoJobId      String?
  mixBackgroundId String?
  uploadId        String?
  cancelRequested Boolean  @default(false)
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([videoJobId])
}
